{
  "manifest_version": 3,
  "name": "ClipGrab",
  "version": "1.0.0",
  "description": "Download and clip videos from X, Instagram, Reddit, Vimeo, Twitch, and Streamable.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClipGrab"
  },
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://*.vercel.app/*"
  ]
}
